Bootstrap: docker
From: debian:bookworm-slim

%labels
    Author thomas cokelaer

%post
    export DEBIAN_FRONTEND=noninteractive

    # Install wget and headless JRE
    apt-get update && apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
        default-jre-headless \
    && rm -rf /var/lib/apt/lists/*

    # Download standalone VarScan JAR
    VERSION=2.4.6
    wget -q https://github.com/dkoboldt/varscan/releases/download/v${VERSION}/VarScan.v${VERSION}.jar \
        -O /usr/local/bin/VarScan.jar

    # Create wrapper script
    echo '#!/bin/bash' > /usr/local/bin/varscan
    echo 'java -jar /usr/local/bin/VarScan.jar "$@"' >> /usr/local/bin/varscan
    chmod +x /usr/local/bin/varscan

    # Purge wget
    apt-get purge -y wget
    apt-get autoremove -y
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    exec varscan "$@"
