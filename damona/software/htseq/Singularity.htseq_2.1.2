Bootstrap: docker
From: python:3.11-slim

%labels
    Author thomas cokelaer

%post
    apt-get update && apt-get install -y gcc libbz2-dev liblzma-dev zlib1g-dev g++ libpng-dev libfreetype6-dev pkg-config
    pip install --no-cache-dir htseq==2.1.2 matplotlib
    apt-get remove -y gcc g++ pkg-config
    apt-get autoremove -y
    apt-get clean

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    exec htseq-count "$@"

%test
    htseq-count --help
    htseq-qa --help
    htseq-count-barcodes --help
