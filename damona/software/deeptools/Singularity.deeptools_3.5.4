Bootstrap: docker
From: python:3.11-slim


%labels
    Author thomas cokelaer

%post

    apt-get update && apt-get install -y gcc g++ zlib1g-dev libbz2-dev \
        liblzma-dev libcurl4-openssl-dev

    pip install --no-cache-dir deeptools==3.5.4

    apt-get remove -y gcc g++
    apt-get autoremove -y
    apt-get clean

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8

%runscript
    exec ${1+"$@"}
