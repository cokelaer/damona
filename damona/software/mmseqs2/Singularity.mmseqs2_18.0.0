Bootstrap: docker
From: debian:bookworm-slim

%labels
    Author thomas cokelaer

%post
    export DEBIAN_FRONTEND=noninteractive

    # Install wget, certificates, and gawk which mmseqs2 often needs
    apt-get update && apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
        gawk \
    && rm -rf /var/lib/apt/lists/*

    # Download mmseqs-linux-avx2 tarball
    wget -q https://github.com/soedinglab/MMseqs2/releases/download/18-8cc5c/mmseqs-linux-avx2.tar.gz \
        -O /tmp/mmseqs.tar.gz

    # Extract mmseqs binary
    tar -xzf /tmp/mmseqs.tar.gz -C /tmp/
    cp /tmp/mmseqs/bin/mmseqs /usr/local/bin/mmseqs
    chmod +x /usr/local/bin/mmseqs

    # Cleanup
    rm -rf /tmp/mmseqs.tar.gz /tmp/mmseqs
    apt-get purge -y wget
    apt-get autoremove -y
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    exec mmseqs "$@"
