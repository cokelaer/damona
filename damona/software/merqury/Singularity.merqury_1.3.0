Bootstrap: docker
From: debian:bookworm-slim

%labels
    Author Antigravity
    Version 1.3.0
    Name merqury

%post
    export DEBIAN_FRONTEND=noninteractive
    
    # Update and install dependencies
    apt-get update -y
    apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
        meryl \
        bedtools \
        samtools \
        r-base-core \
        r-cran-argparse \
        r-cran-ggplot2 \
        r-cran-scales
        
    # Download and extract Merqury
    wget https://github.com/marbl/merqury/archive/refs/tags/v1.3.tar.gz -O /tmp/merqury.tar.gz
    tar -xzf /tmp/merqury.tar.gz -C /opt
    mv /opt/merqury-1.3 /opt/merqury
    rm -f /tmp/merqury.tar.gz

    # Remove temporary apt packages
    apt-get purge -y wget ca-certificates
    apt-get autoremove -y
    apt-get clean -y
    rm -rf /var/lib/apt/lists/*

%environment
    export MERQURY=/opt/merqury
    export PATH=/opt/merqury:$PATH
    export LC_ALL=C

%runscript
    exec "$@"
