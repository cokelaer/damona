Bootstrap: docker
From: debian:bookworm-slim

%labels
    Author thomas cokelaer

%post
    export DEBIAN_FRONTEND=noninteractive

    # Install wget and certificates
    apt-get update && apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

    # Download standalone VSEARCH tarball
    VERSION=2.31.0
    wget -q https://github.com/torognes/vsearch/releases/download/v${VERSION}/vsearch-${VERSION}-linux-x86_64.tar.gz \
        -O /tmp/vsearch.tar.gz

    # Extract binary
    tar -xzf /tmp/vsearch.tar.gz -C /tmp/
    mv /tmp/vsearch-${VERSION}-linux-x86_64/bin/vsearch /usr/local/bin/vsearch
    chmod +x /usr/local/bin/vsearch

    # Cleanup
    rm -rf /tmp/vsearch.tar.gz /tmp/vsearch-${VERSION}-linux-x86_64
    apt-get purge -y wget
    apt-get autoremove -y
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    exec vsearch "$@"
