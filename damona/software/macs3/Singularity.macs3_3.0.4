BootStrap: localimage
From: ../../library/micromamba/micromamba_2.5.0.img

%labels
  maintainer Thomas Cokelaer
  package.name macs3
  package.version 3.0.4
  package.homepage https://pypi.org/project/macs3/
  package.source.url https://github.com/macs3-project/MACS
  package.license BSD-3-Clause

%post
  export PATH=$PATH:/opt/conda/envs/main/bin/
  export OPTS="-q -c conda-forge -c bioconda -n main -y"

  micromamba install $OPTS macs3=3.0.4

  micromamba clean --packages -y
  micromamba clean --all -y

%environment
  export PATH=$PATH:/opt/conda/envs/main/bin/

%runscript
  exec /opt/conda/envs/main/bin/macs3 "$@"
