BootStrap: localimage
From: ../../library/micromamba/micromamba_2.0.5.img

%labels
  maintainer Thomas Cokelaer
  package.name verkko
  package.version 2.3.2
  package.homepage https://github.com/marbl/verkko
  package.source.url https://github.com/marbl/verkko
  package.license PUBLIC DOMAIN

%post
  export PATH=$PATH:/opt/conda/envs/main/bin/
  export OPTS="-q -c conda-forge -c bioconda -n main -y"

  micromamba install $OPTS verkko=2.3.2

  micromamba clean --packages -y
  micromamba clean --all -y

%environment
  export PATH=$PATH:/opt/conda/envs/main/bin/

%runscript
  exec /opt/conda/envs/main/bin/verkko "$@"
