BootStrap: docker
From: ubuntu:24.04

%labels
  maintainer Thomas Cokelaer
  package.name unicycler
  package.version 0.5.1
  package.homepage https://github.com/rrwick/Unicycler
  package.source.url https://github.com/rrwick/Unicycler

%post
  export DEBIAN_FRONTEND=noninteractive
  apt-get update -y
  
  # Install heavy system dependencies + pip/build tools
  apt-get install -y python3 python3-pip git build-essential \
                     spades pilon bowtie2 ncbi-blast+ bcftools zlib1g-dev

  # Install exact unicycler version from GitHub
  pip3 install --break-system-packages --no-cache-dir git+https://github.com/rrwick/Unicycler.git@v0.5.1

  # Cleanup build packages to heavily reduce footprint
  apt-get purge -y git build-essential zlib1g-dev
  apt-get autoremove -y
  apt-get clean
  rm -rf /var/lib/apt/lists/*
  rm -rf /root/.cache/pip

%runscript
  exec unicycler "$@"
