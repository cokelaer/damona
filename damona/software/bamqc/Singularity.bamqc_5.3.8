BootStrap: docker
From: ubuntu:24.04

%labels
  maintainer Thomas Cokelaer
  package.name bamqc
  package.version 5.3.8
  package.homepage https://github.com/s-andrews/BamQC
  package.source.url https://github.com/s-andrews/BamQC

%post
  export DEBIAN_FRONTEND=noninteractive
  apt-get update -y
  
  # Install Java runtime, perl, locales, and build dependencies
  apt-get install -y default-jre default-jdk-headless ant git perl locales

  # Configure locales to suppress Perl warnings
  echo "en_US.UTF-8 UTF-8" > /etc/locale.gen
  locale-gen en_US.UTF-8
  update-locale LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8

  # Clone, patch, and compile BamQC
  git clone https://github.com/s-andrews/BamQC.git /opt/BamQC
  cd /opt/BamQC
  sed -i 's/name="source" value="1.6"/name="source" value="1.8"/g' build.xml
  sed -i 's/name="target" value="1.6"/name="target" value="1.8"/g' build.xml
  ant
  
  # The bamqc script expects .class files in the root /uk/ directory
  # and explicitly crashes if it sees .java files (hardcoded anti-source check)
  cp -r bin/* .
  find . -name "*.java" -delete

  # Make executable and link it
  chmod 755 bamqc
  ln -s /opt/BamQC/bamqc /usr/local/bin/bamqc

  # Cleanup build packages to minimize footprint
  apt-get purge -y default-jdk-headless ant git
  apt-get autoremove -y
  apt-get clean
  rm -rf /var/lib/apt/lists/*

%environment
  export LANG=en_US.UTF-8
  export LC_ALL=en_US.UTF-8

%runscript
  exec bamqc "$@"
