Bootstrap: docker
From: python:3.10-slim
%post
  BUSCO_VERSION=6.0.0
  SAMTOOLS_VERSION=1.17
  BBMAP_VERSION=39.00
  PRODIGAL_VERSION=2.6.3
  AUGUSTUS_VERSION=3.5.0
  SEPP_VERSION=4.5.5
  MINIPROT_VERSION=0.13

  apt-get update && apt-get install -yq --no-install-recommends \
    default-jre ncbi-blast+ hmmer make curl bzip2 g++ \
    libncurses-dev zlib1g-dev libbz2-dev liblzma-dev libcurl4-openssl-dev \
    && rm -rf /var/lib/apt/lists/*

  # install python packages
  pip install --no-cache-dir --upgrade pip
  pip install --no-cache-dir matplotlib pandas biopython requests

  # install samtools
  curl -sSL https://github.com/samtools/samtools/releases/download/$SAMTOOLS_VERSION/samtools-$SAMTOOLS_VERSION.tar.bz2 | tar -xjf - \
    && cd samtools-$SAMTOOLS_VERSION \
    && ./configure && make && make install \
    && cd samtools-${SAMTOOLS_VERSION}/htslib-${SAMTOOLS_VERSION} && make && make install \
    && cd / && rm -rf /samtools-${SAMTOOLS_VERSION}

  ## install augustus and deps
  apt-get update && apt-get install -yq --no-install-recommends \
    libgsl-dev libboost-all-dev libsuitesparse-dev liblpsolve55-dev \
    libsqlite3-dev libmysql++-dev libbamtools-dev \
    && rm -rf /var/lib/apt/lists/*
  curl -sSL https://github.com/Gaius-Augustus/Augustus/archive/refs/tags/v$AUGUSTUS_VERSION.tar.gz | tar zx \
    && mv Augustus-$AUGUSTUS_VERSION augustus && cd augustus && make augustus && make && make install && cd /
  mv /augustus/config /augustusconf && rm -rf /augustus && mkdir /augustus && mv /augustusconf /augustus/config

  ## install prodigal
  curl -sSL https://github.com/hyattpd/Prodigal/archive/refs/tags/v$PRODIGAL_VERSION.tar.gz | tar zx \
    && cd Prodigal-$PRODIGAL_VERSION && make install && cd / && rm -rf /Prodigal-$PRODIGAL_VERSION

  ## install metaeuk
  curl -sSL https://mmseqs.com/metaeuk/metaeuk-linux-avx2.tar.gz | tar zx && ln -s /metaeuk/bin/metaeuk /usr/local/bin/

  ## install BBTools
  curl -sSL https://sourceforge.net/projects/bbmap/files/BBMap_$BBMAP_VERSION.tar.gz | tar zx \
    && ln -s /bbmap/*.sh /usr/local/bin/

  ## install SEPP 4.5.5
  apt-get update && apt-get install -yq --no-install-recommends git && rm -rf /var/lib/apt/lists/*
  curl -sSL https://github.com/smirarab/sepp/archive/refs/tags/v${SEPP_VERSION}.tar.gz | tar zx \
    && cd sepp-${SEPP_VERSION} && python setup.py config && python setup.py install && cd / && rm -rf /sepp-${SEPP_VERSION}
  apt-get purge -yq git && apt-get autoremove -yq && rm -rf /var/lib/apt/lists/*

  ## install miniprot
  curl -sSL https://github.com/lh3/miniprot/archive/refs/tags/v${MINIPROT_VERSION}.tar.gz | tar zx \
    && cd miniprot-${MINIPROT_VERSION} && make && cp miniprot /usr/local/bin/ && cd / && rm -rf /miniprot-${MINIPROT_VERSION}

  ## install BUSCO
  pip install --no-cache-dir https://gitlab.com/ezlab/busco/-/archive/$BUSCO_VERSION/busco-$BUSCO_VERSION.tar.gz

  ## install R + ggplot2 (optional, for plots)
  apt-get update && apt-get install -yq --no-install-recommends r-base && rm -rf /var/lib/apt/lists/*
  R --vanilla -e 'install.packages("ggplot2", repos="http://cran.wu.ac.at/")' \
    && rm -rf /tmp/downloaded_packages /root/.cache

  ## final cleanup
  apt-get purge -yq make g++ libncurses-dev zlib1g-dev libbz2-dev liblzma-dev libcurl4-openssl-dev bzip2 \
    libgsl-dev libboost-all-dev libsuitesparse-dev liblpsolve55-dev \
    libsqlite3-dev libmysql++-dev libbamtools-dev
  apt-get autoremove -yq && apt-get clean && rm -rf /var/lib/apt/lists/*
  pip cache purge || true

%environment
  export AUGUSTUS_CONFIG_PATH="/augustus/config"
  export LC_ALL=C.UTF-8
