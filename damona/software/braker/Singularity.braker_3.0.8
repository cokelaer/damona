BootStrap: docker
From: mambaorg/micromamba:1.3.1

%labels
  maintainer Thomas Cokelaer
  package.name braker
  package.version 3.0.8
  package.homepage https://github.com/Gaius-Augustus/BRAKER

%post
  export DEBIAN_FRONTEND=noninteractive
  # Enforce base activation context internally for micromamba installations
  micromamba install -y -n base -c bioconda -c conda-forge "braker3=3.0.8"
  
  # Violently prune cache layers
  micromamba clean --all --yes
  
  # For Apptainer execution
  echo '. /opt/conda/etc/profile.d/conda.sh' >> /etc/profile
  echo 'conda activate base' >> /etc/profile

%environment
  export PATH=/opt/conda/bin:$PATH

%runscript
  exec braker.pl "$@"
