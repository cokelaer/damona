Bootstrap: localimage
From: micromamba_2.5.0.img

%post

    apt-get update -y
    apt-get install -y --no-install-recommends make curl bzip2 build-essential
    apt-get clean && rm -rf /var/lib/apt/lists/*

    # export the PATH here so that pip is found later on
    export PATH=$PATH:/opt/conda/envs/main/bin/

    # an alias
    export OPTS=" -q -c conda-forge -c bioconda -n main -y "

    micromamba install $OPTS python="3.11"

    pip install --no-cache-dir cython
    pip install --no-cache-dir sequana==0.21.0
    pip cache purge

    micromamba install $OPTS cd-hit kraken2 krona bwa snpeff samtools shustring mosdepth

    # cleanup
    micromamba clean --packages -y
    micromamba clean --all -y
    rm -rf /opt/conda/pkgs

%environment
    export PATH=$PATH:/opt/conda/envs/main/bin/

%runscript
    sequana "$@"

