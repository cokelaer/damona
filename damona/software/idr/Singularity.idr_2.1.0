BootStrap: docker
From: python:3.10-slim

%labels
  maintainer Thomas Cokelaer
  package.name idr
  package.version 2.1.0
  package.homepage https://github.com/sequana/idr
  package.source.url https://github.com/sequana/idr
  package.license GPL3

%post
  apt-get update
  apt-get install -y git gcc python3-dev

  pip install --no-cache-dir git+https://github.com/sequana/idr@v2.1.0

  apt-get purge -y git gcc python3-dev
  apt-get autoremove -y
  apt-get clean
  rm -rf /var/lib/apt/lists/*
  rm -rf /root/.cache/pip

%runscript
  exec idr "$@"
