Bootstrap: docker
From: python:3.12-slim

%labels
  maintainer Thomas Cokelaer
  package.name isoquant
  package.version 3.12.2
  package.homepage https://ablab.github.io/IsoQuant/
  package.source.url https://github.com/ablab/IsoQuant
  package.license GPL-2.0

%post
  ISOQUANT_VERSION=3.12.2
  MINIMAP2_VERSION=2.28
  SAMTOOLS_VERSION=1.21

  apt-get update && apt-get install -yq --no-install-recommends \
    curl bzip2 make gcc g++ \
    zlib1g-dev libbz2-dev liblzma-dev libncurses5-dev libcurl4-openssl-dev \
    && rm -rf /var/lib/apt/lists/*

  # install samtools + htslib (runtime libs needed by pysam)
  curl -sSL https://github.com/samtools/samtools/releases/download/${SAMTOOLS_VERSION}/samtools-${SAMTOOLS_VERSION}.tar.bz2 | tar -jxf - \
    && cd samtools-${SAMTOOLS_VERSION} \
    && ./configure && make && make install \
    && cd htslib-${SAMTOOLS_VERSION} && make && make install \
    && cd / && rm -rf samtools-${SAMTOOLS_VERSION}

  # install minimap2 pre-built binary
  curl -sSL https://github.com/lh3/minimap2/releases/download/v${MINIMAP2_VERSION}/minimap2-${MINIMAP2_VERSION}_x64-linux.tar.bz2 | tar -jxf - \
    && cp minimap2-${MINIMAP2_VERSION}_x64-linux/minimap2 /usr/local/bin/ \
    && rm -rf minimap2-${MINIMAP2_VERSION}_x64-linux

  pip install --no-cache-dir pytz isoquant==${ISOQUANT_VERSION}

  # remove build-only tools (keep runtime libs for pysam/htslib)
  apt-get purge -yq make gcc g++ curl bzip2
  apt-get autoremove -yq
  rm -rf /var/lib/apt/lists/*

%environment
  export LC_ALL=C.UTF-8

%runscript
  exec isoquant.py "$@"
